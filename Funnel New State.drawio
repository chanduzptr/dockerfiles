        <mxCell id="q5VS8YKIH6cqjYuDKug6-39" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1565C0;strokeColor=#0D47A1;fontSize=16;fontStyle=1;fontColor=#FFFFFF;align=center;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;USE CASE 2: Chat to Query &amp;amp; Test Cases&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="730" x="3860" y="1265.5" as="geometry" />
        </mxCell>
        <mxCell id="q5VS8YKIH6cqjYuDKug6-40" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;1. Metadata Retrieval&lt;/b&gt;&lt;br&gt;• User provides table names and natural language prompt&lt;br&gt;• Connects to Snowflake for metadata&lt;br&gt;• Enriches prompt with metadata context&lt;/font&gt;" vertex="1">
          <mxGeometry height="190" width="366.5" x="3832.5" y="1320.5" as="geometry" />
        </mxCell>
        <mxCell id="q5VS8YKIH6cqjYuDKug6-41" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;2. Query Generation&lt;/b&gt;&lt;br&gt;• Retrieves stored context from S3&lt;br&gt;• LLM generates SQL using metadata-enriched prompt and context&lt;br&gt;• Outputs SQL query file&lt;/font&gt;" vertex="1">
          <mxGeometry height="190" width="371" x="4270" y="1320.5" as="geometry" />
        </mxCell>
        <mxCell id="q5VS8YKIH6cqjYuDKug6-42" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b&gt;3. Query Validation &amp;amp; Storage&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span data-teams=&quot;true&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Validates SQL syntax against Snowflake(3 iteration)&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span data-teams=&quot;true&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Captures error and refines queries&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span data-teams=&quot;true&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Stores validated SQL in S3 upon successful validation and returns error for failed queries&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="365.75" x="4071.25" y="1549" as="geometry" />
        </mxCell>
