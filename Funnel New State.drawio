        <mxCell id="q5VS8YKIH6cqjYuDKug6-28" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#E65100;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;LLM Workflows&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="350" x="3895" y="710.5" as="geometry" />
        </mxCell>
        <mxCell id="q5VS8YKIH6cqjYuDKug6-29" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;strokeColor=#E65100;fontSize=16;fontStyle=1;fontColor=#FFFFFF;align=center;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;USE CASE 1: Mapping to Query&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="730" x="3860" y="760.5" as="geometry" />
        </mxCell>
        <mxCell id="q5VS8YKIH6cqjYuDKug6-30" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#FF9800;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;1.&amp;nbsp;&lt;/b&gt;&lt;span data-teams=&quot;true&quot;&gt;&lt;strong&gt;File Processor&amp;nbsp;&lt;br&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&amp;nbsp;&lt;/span&gt;User uploads Excel mapping document&lt;br&gt;• Python API converts Excel → Pandas → Raw JSON&lt;br&gt;• Raw JSON passed to next stage&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="375" x="3830" y="830.5" as="geometry" />
        </mxCell>
        <mxCell id="q5VS8YKIH6cqjYuDKug6-31" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#FF9800;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;2. Mapping Standardization&lt;/b&gt;&lt;br&gt;• LLM processes raw JSON with mapping context&lt;br&gt;• Converts to standardized JSON&amp;nbsp;&lt;br&gt;• Enables consistent downstream processing despite variable input mapping.&lt;/font&gt;" vertex="1">
          <mxGeometry height="180" width="375" x="4270" y="830.5" as="geometry" />
        </mxCell>
        <mxCell id="q5VS8YKIH6cqjYuDKug6-32" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#FF9800;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;3. SQL Generation&lt;/b&gt;&lt;br&gt;• Fetches Snowflake metadata via API&lt;br&gt;• LLM generates SQL using standardized JSON,&lt;br&gt;  metadata context, and standardized prompt&lt;br&gt;• Outputs SQL file for validation&lt;/font&gt;" vertex="1">
          <mxGeometry height="180" width="366.5" x="3832.5" y="1060.5" as="geometry" />
        </mxCell>
        <mxCell id="q5VS8YKIH6cqjYuDKug6-33" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#FF9800;strokeWidth=2;fontSize=13;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b style=&quot;&quot;&gt;4. Query Validation &amp;amp; Storage&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span data-teams=&quot;true&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Validates SQL syntax against Snowflake(3 iteration)&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span data-teams=&quot;true&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Captures error and refines queries&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;span data-teams=&quot;true&quot; style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;•&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Stores validated SQL in S3 upon successful validation and returns error for failed queries&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="375" x="4270" y="1060.5" as="geometry" />
        </mxCell>
        <mxCell id="q5VS8YKIH6cqjYuDKug6-34" edge="1" parent="1" source="q5VS8YKIH6cqjYuDKug6-30" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#FF9800;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="q5VS8YKIH6cqjYuDKug6-31" value="">
