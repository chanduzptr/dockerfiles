        <mxCell id="q5VS8YKIH6cqjYuDKug6-27" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#FF9800;strokeWidth=3;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;fontSize=14;fontStyle=1;" value="" vertex="1">
